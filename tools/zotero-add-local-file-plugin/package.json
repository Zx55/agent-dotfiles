{
  "name": "zotero-add-local-file-plugin",
  "version": "0.1.1",
  "private": true,
  "description": "Minimal Zotero plugin for adding local files as stored attachments.",
  "scripts": {
    "clean": "rm -rf dist build",
    "build:js": "esbuild src/main.ts --bundle --target=firefox115 --format=iife --global-name=ZoteroAddLocalFilePlugin --outfile=dist/main.js",
    "build:xpi": "node scripts/build-xpi.mjs",
    "build": "npm run clean && npm run build:js && npm run build:xpi",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.5"
  }
}
