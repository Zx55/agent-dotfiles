{
  "manifest_version": 2,
  "name": "Zotero Add Local File",
  "version": "0.1.1",
  "description": "Expose a local endpoint for adding local files as Zotero stored attachments.",
  "applications": {
    "zotero": {
      "id": "zotero-add-local-file-plugin@local.addons",
      "update_url": "https://example.com/zotero-add-local-file-plugin/updates.json",
      "strict_min_version": "8.0.1",
      "strict_max_version": "9.*"
    }
  }
}
